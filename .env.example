# SpecScribe — Environment Variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=                        # 64-char hex secret: openssl rand -hex 32

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://specscribe:localdevonly@localhost:5432/specscribe_dev?sslmode=disable
DIRECT_URL=postgresql://specscribe:localdevonly@localhost:5432/specscribe_dev?sslmode=disable  # bypasses pgBouncer for migrations; set to direct DB URL in production

# ─── Auth (Clerk) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_DOMAIN=          # production only: your custom Clerk domain (e.g. accounts.yourapp.com)

# ─── Auth (MFA cookie signing) ──────────────────────────────────────────────
APP_MFA_SECRET=                    # 64-char hex: openssl rand -hex 32 — signs ss_mfa cookie

# ─── E2E test credentials (never set in production) ─────────────────────────
CLERK_TEST_USER_EMAIL=
CLERK_TEST_USER_PASSWORD=
CLERK_TEST_USER_ID=                # Clerk user ID (e.g. user_2abc...) for encounter E2E tests

# ─── AI Services ────────────────────────────────────────────────────────────
# Claude via AWS Bedrock (ca-central-1 for HIA/PIPEDA Canadian data residency)
BEDROCK_AWS_REGION=ca-central-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5:0   # set to the Bedrock model ID available in your account
BEDROCK_AWS_ACCESS_KEY_ID=                        # leave blank to use IAM role (recommended in production)
BEDROCK_AWS_SECRET_ACCESS_KEY=                    # leave blank to use IAM role (recommended in production)
BEDROCK_AWS_SESSION_TOKEN=                        # optional — for temporary credentials / assumed roles

# ─── Storage (AWS S3 / MinIO) ───────────────────────────────────────────────
AWS_S3_BUCKET=specscribe-audio
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000   # remove for real AWS

# ─── Billing (Stripe) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_BASIC=price_...
STRIPE_PRICE_ID_PROFESSIONAL=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# ─── FHIR Integration ───────────────────────────────────────────────────────
FHIR_BASE_URL=https://fhir.example.com/R4
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://:localdevonly@localhost:6379

# ─── Monitoring ─────────────────────────────────────────────────────────────
DATADOG_API_KEY=
SENTRY_DSN=
