# SpecScribe — Environment Variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=                        # 64-char hex secret: openssl rand -hex 32

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://specscribe:localdevonly@localhost:5432/specscribe_dev?sslmode=disable

# ─── Auth (NextAuth) ────────────────────────────────────────────────────────
NEXTAUTH_SECRET=                   # 64-char hex: openssl rand -hex 32
NEXTAUTH_URL=http://localhost:3000

# ─── AI Services ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                 # sk-ant-...
DEEPGRAM_API_KEY=                  # from console.deepgram.com

# ─── Storage (AWS S3 / MinIO) ───────────────────────────────────────────────
AWS_S3_BUCKET=specscribe-audio
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000   # remove for real AWS

# ─── Billing (Stripe) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_BASIC=price_...
STRIPE_PRICE_ID_PROFESSIONAL=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# ─── FHIR Integration ───────────────────────────────────────────────────────
FHIR_BASE_URL=https://fhir.example.com/R4
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://:localdevonly@localhost:6379

# ─── Monitoring ─────────────────────────────────────────────────────────────
DATADOG_API_KEY=
SENTRY_DSN=
