generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp"), vector]
}

model Practice {
  id                    String                 @id @default(dbgenerated("uuid_generate_v4()"))
  name                  String
  specialty             SpecialtyType          @default(behavioral_health)
  npi                   String                 @unique
  tax_id                String?
  address               Json
  phone                 String?
  subscriptionTier      SubscriptionTier       @default(basic)
  stripeCustomerId      String?                @map("stripe_customer_id")
  stripeSubId           String?                @map("stripe_sub_id")
  fhirBaseUrl           String?                @map("fhir_base_url")
  fhirClientId          String?                @map("fhir_client_id")
  settings              Json                   @default("{}")
  active                Boolean                @default(true)
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  deletedAt             DateTime?              @map("deleted_at")
  analyticsEvents       AnalyticsEvent[]
  auditLogs             AuditLog[]
  claims                ClaimSubmission[]
  complianceAlerts      ComplianceAlert[]
  encounters            Encounter[]
  patients              Patient[]
  payerRules            PracticePayerRule[]
  priorAuths            PriorAuthRequest[]
  providerVerifications ProviderVerification[]
  users                 User[]

  @@map("practices")
}

model User {
  id                     String                 @id @default(dbgenerated("uuid_generate_v4()"))
  practiceId             String                 @map("practice_id")
  email                  String                 @unique
  passwordHash           String?                @map("password_hash")
  role                   UserRole               @default(staff)
  firstName              String                 @map("first_name")
  lastName               String                 @map("last_name")
  npi                    String?
  credentials            String?
  passwordHistory        Json                   @default("[]") @map("password_history")
  failedLoginCount       Int                    @default(0) @map("failed_login_count")
  lockedUntil            DateTime?              @map("locked_until")
  lastLoginAt            DateTime?              @map("last_login_at")
  lastLoginIp            String?                @map("last_login_ip")
  active                 Boolean                @default(true)
  invitedAt              DateTime?              @map("invited_at")
  inviteToken            String?                @map("invite_token")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  deletedAt              DateTime?              @map("deleted_at")
  auditLogs              AuditLog[]
  encounters             Encounter[]
  verifications          ProviderVerification[]
  verificationsPerformed ProviderVerification[] @relation("VerifiedBy")
  practice               Practice               @relation(fields: [practiceId], references: [id])

  @@index([practiceId])
  @@map("users")
}

model Patient {
  id            String      @id @default(dbgenerated("uuid_generate_v4()"))
  practiceId    String      @map("practice_id")
  mrn           String
  firstName     String      @map("first_name")
  lastName      String      @map("last_name")
  dob           String      @map("dob")
  sex           String?
  phone         String?
  email         String?
  address       String?
  insuranceJson String?     @map("insurance_json")
  fhirId        String?     @map("fhir_id")
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")
  encounters    Encounter[]
  practice      Practice    @relation(fields: [practiceId], references: [id])

  @@unique([practiceId, mrn])
  @@index([practiceId])
  @@map("patients")
}

model Encounter {
  id             String             @id @default(dbgenerated("uuid_generate_v4()"))
  practiceId     String             @map("practice_id")
  patientId      String             @map("patient_id")
  providerId     String             @map("provider_id")
  encounterDate  DateTime           @map("encounter_date")
  status         EncounterStatus    @default(not_started)
  specialtyType  SpecialtyType      @map("specialty_type")
  audioFileKey   String?            @map("audio_file_key")
  audioDuration  Int?               @map("audio_duration")
  fhirId         String?            @map("fhir_id")
  metadata       Json               @default("{}")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  deletedAt      DateTime?          @map("deleted_at")
  aiInteractions AIInteraction[]
  claims         ClaimSubmission[]
  codes          EncounterCode[]
  notes          EncounterNote[]
  patient        Patient            @relation(fields: [patientId], references: [id])
  practice       Practice           @relation(fields: [practiceId], references: [id])
  provider       User               @relation(fields: [providerId], references: [id])
  priorAuths     PriorAuthRequest[]

  @@index([practiceId])
  @@index([patientId])
  @@index([providerId])
  @@index([encounterDate])
  @@map("encounters")
}

model EncounterNote {
  id                 String     @id @default(dbgenerated("uuid_generate_v4()"))
  encounterId        String     @map("encounter_id")
  noteType           NoteType   @map("note_type")
  noteFormat         NoteFormat @default(SOAP) @map("note_format")
  rawTranscript      String?    @map("raw_transcript")
  aiGeneratedNote    String?    @map("ai_generated_note")
  providerEditedNote String?    @map("provider_edited_note")
  aiAcceptanceRate   Float?     @map("ai_acceptance_rate")
  wordCount          Int?       @map("word_count")
  finalizedAt        DateTime?  @map("finalized_at")
  finalizedBy        String?    @map("finalized_by")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  encounter          Encounter  @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId])
  @@map("encounter_notes")
}

model EncounterCode {
  id                String    @id @default(dbgenerated("uuid_generate_v4()"))
  encounterId       String    @map("encounter_id")
  codeType          CodeType  @map("code_type")
  code              String
  description       String?
  modifier          String?
  units             Int       @default(1)
  aiConfidence      Float?    @map("ai_confidence")
  aiRationale       String?   @map("ai_rationale")
  reasoning         String?
  denial_risk_score Float?
  providerAccepted  Boolean?  @map("provider_accepted")
  providerModified  Boolean   @default(false) @map("provider_modified")
  acceptedAt        DateTime? @map("accepted_at")
  acceptedBy        String?   @map("accepted_by")
  finalCode         String?   @map("final_code")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  version           Int       @default(1)
  supersededAt      DateTime? @map("superseded_at") @db.Timestamptz(6)
  encounter         Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId, supersededAt])
  @@map("encounter_codes")
}

model AIInteraction {
  id              String    @id @default(dbgenerated("uuid_generate_v4()"))
  encounterId     String    @map("encounter_id")
  interactionType String    @map("interaction_type")
  promptHash      String    @map("prompt_hash")
  outputHash      String?   @map("output_hash")
  modelVersion    String    @map("model_version")
  inputTokens     Int       @map("input_tokens")
  outputTokens    Int       @map("output_tokens")
  latencyMs       Int       @map("latency_ms")
  providerAction  String?   @map("provider_action")
  createdAt       DateTime  @default(now()) @map("created_at")
  encounter       Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId])
  @@map("ai_interactions")
}

model SpecialtyTemplate {
  id              String        @id @default(dbgenerated("uuid_generate_v4()"))
  specialty       SpecialtyType
  noteType        NoteType      @map("note_type")
  noteFormat      NoteFormat    @map("note_format")
  templateContent String        @map("template_content")
  promptAddendum  String?       @map("prompt_addendum")
  version         Int           @default(1)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@unique([specialty, noteType, noteFormat, version])
  @@map("specialty_templates")
}

model PriorAuthRequest {
  id                String          @id @default(dbgenerated("uuid_generate_v4()"))
  practiceId        String          @map("practice_id")
  encounterId       String          @map("encounter_id")
  payerId           String          @map("payer_id")
  payerName         String          @map("payer_name")
  procedureCodes    Json            @map("procedure_codes")
  diagnosisCodes    Json            @map("diagnosis_codes")
  status            PriorAuthStatus @default(not_required)
  authNumber        String?         @map("auth_number")
  submittedAt       DateTime?       @map("submitted_at")
  approvedAt        DateTime?       @map("approved_at")
  denied_at         DateTime?
  expiresAt         DateTime?       @map("expires_at")
  denial_reason     String?
  clinicalSummary   String?         @map("clinical_summary")
  supportingDocs    Json            @default("[]") @map("supporting_docs")
  appealDeadline    DateTime?       @map("appeal_deadline")
  appealSubmittedAt DateTime?       @map("appeal_submitted_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  encounter         Encounter       @relation(fields: [encounterId], references: [id])
  practice          Practice        @relation(fields: [practiceId], references: [id])

  @@index([practiceId])
  @@index([encounterId])
  @@map("prior_auth_requests")
}

model ClaimSubmission {
  id              String      @id @default(dbgenerated("uuid_generate_v4()"))
  practiceId      String      @map("practice_id")
  encounterId     String      @map("encounter_id")
  payerId         String      @map("payer_id")
  payerName       String      @map("payer_name")
  codesJson       Json        @map("codes_json")
  billedAmount    Decimal     @map("billed_amount") @db.Decimal(10, 2)
  allowedAmount   Decimal?    @map("allowed_amount") @db.Decimal(10, 2)
  paidAmount      Decimal?    @map("paid_amount") @db.Decimal(10, 2)
  status          ClaimStatus @default(draft)
  submittedAt     DateTime?   @map("submitted_at")
  paidAt          DateTime?   @map("paid_at")
  denial_reason   String?
  denial_code     String?
  appealedAt      DateTime?   @map("appealed_at")
  externalClaimId String?     @map("external_claim_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  encounter       Encounter   @relation(fields: [encounterId], references: [id])
  practice        Practice    @relation(fields: [practiceId], references: [id])

  @@index([practiceId])
  @@index([encounterId])
  @@map("claim_submissions")
}

model PayerRule {
  id            String              @id @default(dbgenerated("uuid_generate_v4()"))
  payerName     String              @map("payer_name")
  payerId       String?             @map("payer_id")
  specialty     SpecialtyType
  ruleType      String              @map("rule_type")
  ruleContent   Json                @map("rule_content")
  effectiveDate DateTime            @map("effective_date")
  endDate       DateTime?           @map("end_date")
  active        Boolean             @default(true)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  practiceRules PracticePayerRule[]

  @@index([payerName, specialty])
  @@map("payer_rules")
}

model PracticePayerRule {
  id          String    @id @default(dbgenerated("uuid_generate_v4()"))
  practiceId  String    @map("practice_id")
  payerRuleId String    @map("payer_rule_id")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  payerRule   PayerRule @relation(fields: [payerRuleId], references: [id])
  practice    Practice  @relation(fields: [practiceId], references: [id])

  @@unique([practiceId, payerRuleId])
  @@map("practice_payer_rules")
}

model ComplianceAlert {
  id          String                  @id @default(dbgenerated("uuid_generate_v4()"))
  practiceId  String                  @map("practice_id")
  alertType   String                  @map("alert_type")
  severity    ComplianceAlertSeverity
  title       String
  description String
  entityType  String?                 @map("entity_type")
  entityId    String?                 @map("entity_id")
  resolvedAt  DateTime?               @map("resolved_at")
  resolvedBy  String?                 @map("resolved_by")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  practice    Practice                @relation(fields: [practiceId], references: [id])

  @@unique([practiceId, alertType])
  @@index([practiceId])
  @@index([resolvedAt])
  @@map("compliance_alerts")
}

model KnowledgeChunk {
  id         String                 @id @default(dbgenerated("uuid_generate_v4()"))
  sourceType String                 @map("source_type")
  sourceId   String                 @map("source_id")
  specialty  SpecialtyType?
  content    String
  metadata   Json                   @default("{}")
  embedding  Unsupported("vector")?
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  @@index([sourceType, specialty])
  @@map("knowledge_chunks")
}

model AuditLog {
  id             String      @id @default(dbgenerated("uuid_generate_v4()"))
  practiceId     String      @map("practice_id")
  userId         String?     @map("user_id")
  userRole       String?     @map("user_role")
  sessionId      String?     @map("session_id")
  action         AuditAction
  resource       String
  resourceId     String?     @map("resource_id")
  ipAddress      String?     @map("ip_address")
  userAgent      String?     @map("user_agent")
  outcome        String      @default("success")
  errorCode      String?     @map("error_code")
  fieldsAccessed Json?       @map("fields_accessed")
  fieldsChanged  Json?       @map("fields_changed")
  metadata       Json        @default("{}")
  previousHash   String?     @map("previous_hash")
  entryHash      String?     @map("entry_hash")
  timestamp      DateTime    @default(now())
  practice       Practice    @relation(fields: [practiceId], references: [id])
  user           User?       @relation(fields: [userId], references: [id])

  @@index([practiceId, timestamp])
  @@index([userId])
  @@map("audit_log")
}

model AnalyticsEvent {
  id           String   @id @default(dbgenerated("uuid_generate_v4()"))
  practiceId   String   @map("practice_id")
  eventType    String   @map("event_type")
  metadataJson Json     @default("{}") @map("metadata_json")
  timestamp    DateTime @default(now())
  practice     Practice @relation(fields: [practiceId], references: [id])

  @@index([practiceId, eventType, timestamp])
  @@map("analytics_events")
}

model ProviderVerification {
  id                 String   @id @default(dbgenerated("uuid_generate_v4()"))
  practiceId         String   @map("practice_id")
  userId             String   @map("user_id")
  verifiedById       String   @map("verified_by_id")
  province           String
  registrationNumber String   @map("registration_number")
  college            String
  inGoodStanding     Boolean  @map("in_good_standing")
  verifiedAt         DateTime @map("verified_at")
  expiresAt          DateTime @map("expires_at")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  practice           Practice @relation(fields: [practiceId], references: [id])
  user               User     @relation(fields: [userId], references: [id])
  verifiedBy         User     @relation("VerifiedBy", fields: [verifiedById], references: [id])

  @@index([practiceId])
  @@index([userId])
  @@map("provider_verifications")
}

enum UserRole {
  provider
  admin
  biller
  staff
  superadmin
}

enum EncounterStatus {
  not_started
  in_progress
  ai_processing
  needs_review
  note_finalized
  finalized
}

enum SpecialtyType {
  behavioral_health
  dermatology
  orthopedics
  pain_management
  oncology
}

enum NoteType {
  progress_note
  intake
  biopsychosocial
  treatment_plan
  procedure
  consultation
  discharge
}

enum NoteFormat {
  SOAP
  DAP
  BIRP
  NARRATIVE
}

enum CodeType {
  CPT
  ICD10
  HCPCS
}

enum ClaimStatus {
  draft
  submitted
  pending
  paid
  denied
  appealed
  written_off
}

enum PriorAuthStatus {
  not_required
  pending_submission
  submitted
  under_review
  approved
  denied
  appealed
  expired
}

enum ComplianceAlertSeverity {
  info
  warning
  critical
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  EXPORT
  LOGIN
  LOGOUT
  MFA_VERIFY
  MFA_SETUP
  FAILED_AUTH
  PERMISSION_CHANGE
  CONFIG_CHANGE
  AI_INVOCATION
}

enum SubscriptionTier {
  basic
  professional
  enterprise
}
